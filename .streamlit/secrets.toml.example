# En local : copiez ce fichier en .streamlit/secrets.toml (ne pas committer !)
# Sur Streamlit Community Cloud : collez ce contenu dans
# App settings > Secrets, avec les vraies valeurs.

TENANT_ID = "votre-tenant-id"
CLIENT_ID = "votre-client-id"
CLIENT_SECRET = "votre-client-secret"

# En local :
# REDIRECT_URI = "http://localhost:8501"
# Une fois déployé sur Streamlit Cloud, remplacez par l'URL publique de l'app,
# ex: "https://votre-app.streamlit.app"
REDIRECT_URI = "http://localhost:8501"

STEPUP_ACR_VALUE = "c3"
